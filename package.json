{
  "name": "organhrm-automation",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate-data": "node scripts/generate-test-data.js",
    "pretest": "node scripts/generate-test-data.js",
    "test": "cypress run --spec 'cypress/e2e/login/**/*.cy.js,cypress/e2e/recruitment/**/*.cy.js'",
    "test:all": "cypress run",
    "test:login": "cypress run --spec 'cypress/e2e/login/**/*.cy.js'",
    "test:recruitment": "cypress run --spec 'cypress/e2e/recruitment/**/*.cy.js'",
    "test:report": "cypress run --spec 'cypress/e2e/login/**/*.cy.js,cypress/e2e/recruitment/**/*.cy.js'",
    "test:cloud": "cypress run --record --spec 'cypress/e2e/login/**/*.cy.js,cypress/e2e/recruitment/**/*.cy.js'",
    "ci": "npm run generate-data && npm test",
    "ci:login": "npm run generate-data && npm run test:login",
    "ci:recruitment": "npm run generate-data && npm run test:recruitment",
    "open": "cypress open -e runner=interactive",
    "format": "prettier . --write",
    "lint": "eslint cypress scripts --ext .js --max-warnings=0"
  },
  "devDependencies": {
    "axios": "~1.13.1",
    "cypress": "^13.6.4",
    "cypress-mochawesome-reporter": "^3.8.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-cypress": "^2.15.1",
    "eslint-plugin-jest": "^27.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "xlsx": "^0.18.5"
  }
}
